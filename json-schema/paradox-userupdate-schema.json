{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UserUpdate",
  "title": "UserUpdate",
  "type": "object",
  "description": "Request body for updating an existing user",
  "properties": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone_number": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "language_preference": {
      "type": "string"
    },
    "employee_id": {
      "type": "string"
    },
    "job_title": {
      "type": "string"
    }
  }
}